# Copy this file to .env for local development. Never commit real credentials.

# Application
APP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080
# Generate a random 32-byte key and encode it as base64. Do not reuse this example.
APP_MASTER_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY
DATA_DIR=./data

# PostgreSQL / pgvector
POSTGRES_DB=ai_bot
POSTGRES_USER=ai_bot
POSTGRES_PASSWORD=change_me_for_local_development
POSTGRES_PORT=5432
DATABASE_URL=postgres://ai_bot:change_me_for_local_development@localhost:5432/ai_bot?sslmode=disable
# Keep the official image name by default. A domestic proxy prefix may be supplied locally.
PGVECTOR_IMAGE=pgvector/pgvector:pg18

# Initial administrator. The application only uses these values when no administrator exists.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately

# Browser session; enable this behind public HTTPS.
COOKIE_SECURE=false

# Runtime setting seeds. These values are used only when the database has no
# runtime_defaults row yet. After first startup, edit them in the admin UI.
DEFAULT_CONTEXT_LIMIT=20
AI_REQUEST_TIMEOUT=90s
MESSAGE_RETENTION_DAYS=90

# Worker execution
WORKER_POLL_INTERVAL=1s

# QQ OpenAPI endpoints. Override these only for a proxy or automated tests.
QQ_API_BASE_URL=https://api.sgroup.qq.com
QQ_TOKEN_URL=https://bots.qq.com/app/getAppAccessToken
