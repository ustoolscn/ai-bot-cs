# Image imported with docker load or pulled from your own registry.
AI_BOT_IMAGE=ai-bot:latest

# The password portion must be URL-encoded when it contains reserved URL characters.
DATABASE_URL=postgres://ai_bot:replace_with_url_encoded_password@host.docker.internal:5432/ai_bot?sslmode=disable

# Generate with: openssl rand -base64 32
# Keep this value stable and backed up. Changing it makes stored credentials unreadable.
APP_MASTER_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY

# Used only when the database has no administrator yet.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_INITIAL_PASSWORD

COOKIE_SECURE=true
